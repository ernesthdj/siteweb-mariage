# =============================================================================
# Atypique CMS — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# Supabase — récupérer depuis Settings > API dans le dashboard Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...votre-anon-key

# Cloudinary — configurées dans les secrets de l'Edge Function Supabase
# (ne pas mettre dans le .env local, uniquement sur Supabase)
# CLOUDINARY_CLOUD_NAME=votre-cloud-name
# CLOUDINARY_API_KEY=votre-api-key
# CLOUDINARY_API_SECRET=votre-api-secret
